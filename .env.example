# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in the real values. Never commit ".env".
# ---------------------------------------------------------------------------

# -- Application ------------------------------------------------------------
PROJECT_NAME="Devis Generation API"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# -- Database (matches docker-compose defaults) -----------------------------
POSTGRES_USER=devis
POSTGRES_PASSWORD=devis
POSTGRES_DB=devis
POSTGRES_PORT=5432

# Async DSN used at runtime by SQLAlchemy + asyncpg
DATABASE_URL=postgresql+asyncpg://devis:devis@localhost:5432/devis

# Optional - sync DSN used by Alembic. Auto-derived from DATABASE_URL if empty.
# SYNC_DATABASE_URL=postgresql+psycopg2://devis:devis@localhost:5432/devis

DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# -- Scaleway AI (OpenAI-compatible endpoint) -------------------------------
# Get these from https://console.scaleway.com/generative-api
SCALEWAY_API_KEY=replace-me
SCALEWAY_BASE_URL=https://api.scaleway.ai/<project-uuid>/v1
SCALEWAY_MODEL=gpt-oss-120b

# -- OpenAI -----------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_REASONING_EFFORT=minimal
OPENAI_SERVICE_TIER=priority
OPENAI_PROMPT_CACHE_KEY=travaux-ia-devis-v2
OPENAI_CHATBOT_MODEL=gpt-4
OPENAI_MOBILE_MODEL=gpt-4o-mini
OPENAI_LANDING_MODEL=gpt-4o-mini
OPENAI_VOICE_TRANSCRIPTION_MODEL=gpt-4o-transcribe
# Deprecated — leave empty so Whisper auto-detects the language.
OPENAI_VOICE_TRANSCRIPTION_LANGUAGE=
# Comma-separated allowlist of ISO-639-1 codes. Any other detected language is rejected (returns "").
# Example: "fr,en" accepts French and English only. Leave empty to allow all.
OPENAI_VOICE_TRANSCRIPTION_ALLOWED_LANGUAGES=fr,en
OPENAI_VOICE_TRANSCRIPTION_PROMPT="Transcris uniquement les mots reellement prononces. N'ajoute aucun mot qui n'a pas ete dit. Si l'audio est silencieux, contient seulement du bruit, ou est inintelligible, retourne une transcription vide."

# -- CORS -------------------------------------------------------------------
# JSON array string, e.g. '["http://localhost:3000","https://app.example.com"]'
BACKEND_CORS_ORIGINS=[]
